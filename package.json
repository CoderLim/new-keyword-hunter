{
  "name": "new-keyword-hunter",
  "displayName": "新词挖掘助手",
  "version": "1.0.0",
  "description": "Chrome extension for mining emerging keywords from Google Trends",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "plasmo build && cp -r static/side-panel.* build/chrome-mv3-prod/ && node scripts/fix-manifest.js build/chrome-mv3-prod/manifest.json",
    "package": "plasmo package",
    "test:unit": "rm -rf .tmp-tests && tsc -p tsconfig.test.json && echo '{\"type\":\"commonjs\"}' > .tmp-tests/package.json && node --test .tmp-tests/tests/*.test.js"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@plasmohq/rps": "^1.8.7",
    "@types/chrome": "^0.0.302",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.3"
  },
  "manifest": {
    "host_permissions": [
      "*://trends.google.com/*"
    ],
    "permissions": [
      "webRequest",
      "storage",
      "tabs",
      "downloads",
      "sidePanel"
    ]
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
